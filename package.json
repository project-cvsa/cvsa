{
	"name": "cvsa",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bunx --bun turbo run dev",
		"build": "bunx --bun turbo run build",
		"lint": "biome check .",
		"lint:fix": "biome check --write --unsafe .",
		"format": "biome format --write .",
		"test": "bunx --bun turbo run test",
		"typecheck": "bunx --bun turbo typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"turbo": "^2.8.16"
	},
	"packageManager": "bun@1.3.10"
}
