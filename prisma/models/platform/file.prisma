model File {
    id           Int      @id @default(autoincrement())
    originalName String?  @map("original_name")
    path         String?
    user         User     @relation(fields: [userId], references: [id])
    userId       Int      @map("user_id")
    createdAt    DateTime @default(now()) @map("created_at")

    @@map("file")
    @@schema("platform")
}
