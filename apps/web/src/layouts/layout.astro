---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: URL;
	type?: "website" | "article";
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

		<title>{title}</title>
		<meta name="description" content={description}>
		<meta name="robots" content="index, follow">

		<link rel="icon" href="/favicon.ico">
		<link rel="apple-touch-icon" href="/apple-touch-icon.png">
		<link rel="manifest" href="/site.webmanifest">

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
			href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@90,800&family=IBM+Plex+Mono&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
			rel="stylesheet"
		>

		<style>
		body {
			font-family: "Inter", system-ui, sans-serif;
		}
		</style>
		<slot name="head" />
	</head>

	<body class="dark:bg-[#020203] dark:text-white overflow-x-hidden">
		<slot />
	</body>
</html>
